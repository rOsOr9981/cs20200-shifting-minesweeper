<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ShiftingMinesweeper.MainWindow"
        Title="Shifting Minesweeper"
        Width="520" Height="640"
        CanResize="False"
        Background="#1F1F22">
    <Grid RowDefinitions="Auto,*,Auto" Margin="16">

        <!-- Top status bar -->
        <Grid Grid.Row="0" ColumnDefinitions="*,*,*,Auto" Margin="0,0,0,12">
            <StackPanel Grid.Column="0">
                <TextBlock Text="REVEALS TO QUAKE" Foreground="#888" FontSize="10"/>
                <TextBlock x:Name="QuakeCounter" Text="5" FontSize="26" FontWeight="Bold" Foreground="#FFD93D"/>
            </StackPanel>
            <StackPanel Grid.Column="1">
                <TextBlock Text="FLAGS USED" Foreground="#888" FontSize="10"/>
                <TextBlock x:Name="FlagCounter" Text="0 / 10" FontSize="26" FontWeight="Bold" Foreground="#FF6B6B"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="STATUS" Foreground="#888" FontSize="10"/>
                <TextBlock x:Name="StatusLabel" Text="Playing" FontSize="26" FontWeight="Bold" Foreground="#6BCB77"/>
            </StackPanel>
            <Button Grid.Column="3" x:Name="RestartButton" Content="Restart"
                    Padding="14,6" VerticalAlignment="Center" FontWeight="Bold"/>
        </Grid>

        <!-- Board area -->
        <Border Grid.Row="1" x:Name="BoardContainer"
                Background="#101012" CornerRadius="6" Padding="4">
            <UniformGrid x:Name="BoardGrid" Rows="9" Columns="9"/>
        </Border>

        <!-- Footer hint -->
        <TextBlock Grid.Row="2"
                   Text="Left-click: Reveal   |   Right-click: Flag   |   Every 5th reveal triggers EARTHQUAKE"
                   Foreground="#888" FontSize="11" Margin="0,10,0,0"
                   HorizontalAlignment="Center"/>
    </Grid>
</Window>
